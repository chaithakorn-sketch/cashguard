# ===== Supabase (project: carcamstore-hr / uwniugxetyikjzkobifp, schema: cashguard) =====
SUPABASE_URL=https://uwniugxetyikjzkobifp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__paste_service_role_key__

# ===== LINE OA "Cammo | ผู้ช่วย CCS" =====
LINE_CHANNEL_ACCESS_TOKEN=__paste_channel_access_token__
LINE_CHANNEL_SECRET=__paste_channel_secret__
# Bot's own userId — used by the @tag mention-gate on older webhooks that omit
# mention.isSelf. Get it from GET https://api.line.me/v2/bot/info (field userId).
LINE_BOT_USER_ID=__U....__

# ===== Slip verification (Slip2Go — same provider as the POS) =====
# Reuse the CarcamStore POS Slip2Go key. Empty = slip verify runs as a no-op stub.
SLIP2GO_API_KEY=__paste_slip2go_key__

# ===== OCR (OpenAI-compatible vision; empty = typed-amount-only) =====
OCR_API_KEY=__optional_vision_key__
# OCR_API_URL / OCR_MODEL — optional overrides (default: Gemini compat, gemini-2.5-flash-lite)

# ===== Web app (LIFF edit link) =====
LIFF_EDIT_URL=https://liff.line.me/__liff_id__   # success cards deep-link here (?entry=<id> appended)
# LIFF ID for the /edit web app (client-side). Endpoint URL in LINE console = https://<app>/edit
NEXT_PUBLIC_LIFF_ID=__liff_id__

# ===== Assets (โลโก้ + ไอคอน ที่ host ไว้) =====
ASSET_BASE=https://your-app.vercel.app/cashguard

# ===== Security =====
CRON_SECRET=__random_long_string__       # ป้องกัน cron endpoint
ADMIN_GROUP_ID=__line_group_id_ของกลุ่มผู้บริหาร__

# ===== Draft basket =====
BASKET_TIMEOUT_MINUTES=10
